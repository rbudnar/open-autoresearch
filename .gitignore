# Python
__pycache__/
*.pyc

# Protocol 0.5: derived aggregates are regenerated from state/ledger/*.json,
# never committed. CI (validate-examples) regenerates them before use.
# (template/.gitignore enforces the same rule inside consumer repos.)
examples/**/state/experiment_ledger.jsonl
examples/**/state/research_tree.json
examples/**/state/val_exposure.json
examples/**/state/INDEX.md

# Crash-safety: regenerate_state.py writes derived files via mkstemp(prefix=".tmp-")
# in state/ before os.replace; a crash mid-write can leave one behind. Never commit it.
examples/**/state/.tmp-*
.tmp-*
